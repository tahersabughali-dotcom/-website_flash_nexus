# Flash Nexus — Environment Variables
# Copy this file to .env.local and fill in values from your Supabase project dashboard.
# Never commit .env.local or real secrets to version control.

# ------------------------------------------------------------------------------
# Public Supabase (safe for browser — used by client components)
# Found in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Legacy anon key name (Dashboard → API → anon / public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Newer Supabase publishable key name (supported as fallback in lib/supabase/env.ts)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ------------------------------------------------------------------------------
# Service role key — SERVER ONLY
# ------------------------------------------------------------------------------
# NEVER expose this in client components, NEXT_PUBLIC_* variables, or browser bundles.
# Use only in server-side code via lib/supabase/admin.ts for controlled platform tasks.
# Bypasses RLS — use sparingly and never for normal user operations.
# Found in: Supabase Dashboard → Project Settings → API → service_role (secret)
# ------------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# Application (optional — used in later phases)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
